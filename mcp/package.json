{
  "name": "@cernova/mcp",
  "version": "0.1.0",
  "description": "MCP server for Cernova — lets an agent read scored LLM traces, detected anomalies, and the call sites that produced them",
  "type": "module",
  "bin": {
    "cernova-mcp": "dist/index.js"
  },
  "files": ["dist", "README.md"],
